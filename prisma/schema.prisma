generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   @default("general") // general, research, coding, writing, voice, orchestration
  status      String   @default("idle") // idle, running, error, paused
  avatar      String?
  systemPrompt String?
  soulMd      String?  // SOUL.md personality configuration
  model       String   @default("default")
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  tasks       Task[]
  memories    Memory[]
  conversations Conversation[]
  skills      Skill[]
  goals       Goal[]
  delegates   Delegate[]
  artifacts   Artifact[]
  cronJobs    CronJob[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([status])
  @@index([type])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String
  color       String   @default("#6366f1")
  agents      Agent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo") // todo, in_progress, review, done
  priority    String   @default("medium") // low, medium, high, urgent
  column      String   @default("todo")
  order       Int      @default(0)
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  tags        String?  // comma-separated tags
  dueDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([column])
  @@index([priority])
}

model Memory {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("note") // note, document, reference, log
  tags        String?  // comma-separated tags
  folder      String   @default("General")
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([folder])
  @@index([type])
  @@index([isPinned])
}

model Conversation {
  id          String   @id @default(cuid())
  title       String
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  messages    Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String       // user, assistant, system
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?
  trigger     String   // event type: on_message, on_task_create, on_schedule, on_agent_idle
  action      String   // action type: send_message, create_task, run_agent, notify
  config      String   // JSON config
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([trigger])
}

model ActivityLog {
  id        String   @id @default(cuid())
  agentId   String?
  agentName String?
  action    String
  details   String?
  type      String   @default("info") // info, success, warning, error
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([agentId])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   @default("general") // general, research, coding, writing, automation, communication
  steps       String   // JSON array of steps
  triggers    String?  // when to use this skill
  isAutoLearned Boolean @default(false) // was this skill auto-created by an agent?
  usageCount  Int      @default(0)
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([category])
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("active") // active, completed, abandoned
  priority    String   @default("medium") // low, medium, high, urgent
  progress    Int      @default(0) // 0-100 percentage
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  dueDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([status])
}

model Delegate {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("pending") // pending, running, completed, failed
  task        String   // what the delegate should do
  result      String?  // result when completed
  parentAgentId String
  parentAgent Agent   @relation(fields: [parentAgentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentAgentId])
  @@index([status])
}

model McpServer {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String
  status      String   @default("disconnected") // connected, disconnected, error
  toolsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Artifact {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("html") // html, react, code, markdown, json, css, text
  content     String   // the actual code/content
  preview     String?  // rendered preview URL or base64 screenshot
  status      String   @default("draft") // draft, building, ready, error, deployed
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  taskId      String?  // linked task that created this
  tags        String?
  version     Int      @default(1)
  isPublic    Boolean  @default(false)
  versions    ArtifactVersion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([type])
  @@index([status])
  @@index([isPublic])
}

model ArtifactVersion {
  id          String   @id @default(cuid())
  artifactId  String
  artifact    Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  version     Int
  content     String
  title       String
  type        String
  changeNote  String?  // optional description of what changed
  createdAt   DateTime @default(now())

  @@unique([artifactId, version])
  @@index([artifactId])
  @@index([createdAt])
}

model CronJob {
  id            String   @id @default(cuid())
  name          String
  description   String?
  schedule      String   // cron expression: "*/5 * * * *" or shorthand: "@hourly", "@daily"
  timezone      String   @default("UTC")
  action        String   // run_agent, create_task, send_message, notify, webhook
  config        String   // JSON config for the action
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // system-managed jobs can't be deleted
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  runCount      Int      @default(0)
  failCount     Int      @default(0)
  lastError     String?
  lastDuration  Int?     // ms
  agentId       String?  // optional: linked agent
  agent         Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  executions    CronExecution[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([nextRunAt])
  @@index([agentId])
  @@index([action])
}

model CronExecution {
  id          String   @id @default(cuid())
  cronJobId   String
  cronJob     CronJob  @relation(fields: [cronJobId], references: [id], onDelete: Cascade)
  status      String   @default("running") // running, success, failed, timeout
  startedAt   DateTime @default(now())
  completedAt DateTime?
  duration    Int?     // ms
  result      String?  // JSON result summary
  error       String?  // error message if failed
  triggerType String   @default("scheduled") // scheduled, manual

  @@index([cronJobId])
  @@index([status])
  @@index([startedAt])
}
